htmlcov/
.tox/
.nosenv/
.pytest_cache/
.cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
*.cover
nosetests.xml
coverage.xml
*.deprecated

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
doc/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share this among the developers.
#   See https://github.com/pyenv/pyenv#understanding-python-version-file
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing a setup.py / pyproject.toml setup, you might not use it.

# PEP 582; used by e.g. pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parses files with a .sage extension to pure .py files; ignore those.
*.sage.py

